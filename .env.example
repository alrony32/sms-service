APP_PORT=8080

# Redis (enable persistence in redis.conf: appendonly yes)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

API_KEY=change-me

# SMS provider: "log" (no-op, logs only) or "dhakacolo" (real HTTP)
SMS_DRIVER=log

# DhakaColo provider settings (used when SMS_DRIVER=dhakacolo)
DHAKACOLO_URL=
DHAKACOLO_API_KEY=
DHAKACOLO_SENDER=
DHAKACOLO_BATCH_SIZE=50
DHAKACOLO_RATE_PER_MIN=60

# Webhook delivery (per-client rate limit protects client backends)
WEBHOOK_RATE_PER_MIN=30
WEBHOOK_TIMEOUT_SEC=10
WEBHOOK_MAX_RETRIES=5

# Dispatcher/webhook loop idle sleep (ms) when queues are empty
SCHEDULER_INTERVAL_MS=1000
